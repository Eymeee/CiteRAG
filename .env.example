# Environment variables consumed by the current codebase.
# Copy this file to `.env` and adjust values as needed.

# Ollama model used for generation (FastAPI + Streamlit)
CITERAG_OLLAMA_MODEL=llama3.2

# Ollama server URL
CITERAG_OLLAMA_BASE_URL=http://localhost:11434

# Sentence-transformers model used for ingestion/retrieval
CITERAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional log level for Streamlit app (DEBUG, INFO, WARNING, ERROR)
CITERAG_LOG_LEVEL=INFO
