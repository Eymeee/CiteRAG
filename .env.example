# ==============================
# LLM (Ollama - Local Model)
# ==============================

# Make sure this matches a model you pulled with:
# ollama pull llama3:8b-instruct
OLLAMA_MODEL=llama3:8b-instruct


# ==============================
# Embeddings (Local)
# ==============================

# Sentence-transformers model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2


# ==============================
# Storage Paths
# ==============================

# Where FAISS index + metadata are stored
DATA_DIR=data

# Where uploaded PDFs are stored
UPLOADS_DIR=uploads

# FAISS index file name (inside DATA_DIR)
FAISS_INDEX_NAME=faiss.index

# Metadata file name (inside DATA_DIR)
METADATA_NAME=metadata.json


# ==============================
# Chunking
# ==============================

# Chunk size in characters
CHUNK_SIZE=1000

# Overlap between chunks
CHUNK_OVERLAP=150


# ==============================
# Retrieval
# ==============================

# Number of chunks to retrieve
TOP_K=5

# Minimum cosine similarity score (0–1)
MIN_RELEVANCE_SCORE=0.25


# ==============================
# API
# ==============================

# Backend API URL (used by Streamlit UI)
API_URL=http://localhost:8000
